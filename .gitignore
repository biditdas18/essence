# Ignore Python cache
__pycache__/
*.pyc

# Ignore Jupyter checkpoint files
.ipynb_checkpoints/

# Ignore large binary/data files (rebuild or download locally)
embeddings/*.index
embeddings/*.npy
embeddings/*.pkl
data/raw/
data/*.tsv
data/*.csv
data/*.gz
data/*.zip

# Ignore virtual environment
.venv/

# Ignore OS/macOS files
.DS_Store

# Ignore temporary log or output files
*.log
*.tmp

# Amazon raw data and large binary files
data/amazon_raw/
*.pkl
embeddings/
debug/

